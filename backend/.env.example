# 伺服器埠號
PORT=4000

# JWT 簽章密鑰，部署前請務必更換成一組隨機長字串
JWT_SECRET=請換成一組至少32字元的隨機密鑰

# JWT 有效期限
JWT_EXPIRES_IN=7d

# SQLite 資料庫檔案路徑
DB_PATH=./studyseal.db

# 允許跨網域請求的前端網址（正式環境請填你的前端網域，例如 https://studyseal.onrender.com）
CORS_ORIGIN=*

# 共用帳號中心。第三步完成接線後預設仍為 off；帳號搬移完成再切 required。
IDENTITY_SERVICE_URL=http://localhost:4200
IDENTITY_AUTH_MODE=off
IDENTITY_TIMEOUT_MS=5000
